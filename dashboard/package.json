{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build:results": "node scripts/fetch-results.js",
    "prebuild": "npm run build:results",
    "build": "next build",
    "export": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "start:standalone": "node .next/standalone/server.js",
    "serve": "npx serve@latest out --listen 0.0.0.0 --no-clipboard",
    "deploy": "./scripts/deploy-cloudflare.sh production",
    "deploy:staging": "./scripts/deploy-cloudflare.sh staging",
    "deploy:skip-build": "./scripts/deploy-cloudflare.sh production true",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf .next out coverage test-results",
    "audit": "npm audit",
    "test": "jest",
    "test:watch": "jest --watch --testPathPattern=__tests__/(unit|smoke)/",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:unit": "jest --testPathPattern=__tests__/(unit|components|lib)/",
    "test:smoke": "jest --testPathPattern=__tests__/smoke/",
    "test:regression": "jest --testPathPattern=__tests__/regression/",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "node scripts/test-runner.js all",
    "test:full": "node scripts/test-runner.js all && npm run test:e2e",
    "test:quick": "node scripts/test-runner.js unit && npm run test:smoke"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.8.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.1.2",
    "typescript": "^5"
  }
}
