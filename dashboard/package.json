{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build:results": "node scripts/fetch-results.js",
    "prebuild": "npm run build:results",
    "build": "next build",
    "export": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "start:standalone": "node .next/standalone/server.js",
    "serve": "npx serve@latest out --listen 0.0.0.0 --no-clipboard",
    "deploy": "./scripts/deploy-cloudflare.sh production",
    "deploy:staging": "./scripts/deploy-cloudflare.sh staging",
    "deploy:skip-build": "./scripts/deploy-cloudflare.sh production true",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
