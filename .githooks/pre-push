#!/bin/sh
# Pre-push hook for Atheon-Benchmark
# Runs before push to ensure code quality

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "Running pre-push checks..."

# Get the branch name
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "unknown")

echo "Pushing to branch: $BRANCH"

# Check if we're pushing to main or develop directly
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
    echo "${RED}WARNING: You are pushing directly to $BRANCH!${NC}"
    echo "Consider using a pull request instead."
    echo ""
    read -p "Continue? (y/N) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo "Push cancelled."
        exit 1
    fi
fi

# Check for sensitive data patterns before pushing
echo "Checking for sensitive data..."

SENSITIVE_PATTERNS="api[_-]?key|secret|password|token|private[_-]?key"
if git log -1 --name-only | grep -iE "$SENSITIVE_PATTERNS" > /dev/null 2>&1; then
    echo "${RED}ERROR: Potential sensitive data in last commit${NC}"
    echo "Please ensure no API keys, secrets, or passwords are committed."
    exit 1
fi

echo "${GREEN}Pre-push checks passed!${NC}"
exit 0
