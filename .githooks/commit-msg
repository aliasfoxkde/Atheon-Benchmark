#!/bin/sh
# Pre-commit hook for Atheon-Benchmark
# This hook runs before each commit to enforce code quality

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "Running pre-commit hooks..."

# Get the staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Check for versioned files (ANTI-PATTERN)
VERSIONED_PATTERN='(_v[0-9]+|_new|_backup|_old|\.bak)$'
echo "$STAGED_FILES" | grep -E "$VERSIONED_PATTERN" > /dev/null 2>&1
if [ $? -eq 0 ]; then
    echo "${RED}ERROR: Versioned files detected!${NC}"
    echo "The following files appear to be versioned:"
    echo "$STAGED_FILES" | grep -E "$VERSIONED_PATTERN"
    echo ""
    echo "Use git for version control instead of creating versioned files."
    exit 1
fi

# Check for console.log statements in JS/TS files
JS_TS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|jsx|ts|tsx)$' | grep -v node_modules)
if [ -n "$JS_TS_FILES" ]; then
    CONSOLE_LOG=$(echo "$JS_TS_FILES" | xargs grep -l 'console\.log' 2>/dev/null || true)
    if [ -n "$CONSOLE_LOG" ]; then
        echo "${YELLOW}WARNING: console.log statements detected in:${NC}"
        echo "$CONSOLE_LOG"
        echo "${YELLOW}Consider using the logger utility instead.${NC}"
        # Uncomment below to make this an error:
        # exit 1
    fi
fi

# Check for TODO/FIXME without issue references
TODO_FILES=$(echo "$JS_TS_FILES" | xargs grep -lE '(TODO|FIXME):' 2>/dev/null || true)
if [ -n "$TODO_FILES" ]; then
    echo "${YELLOW}NOTE: TODO/FIXME comments found in:${NC}"
    echo "$TODO_FILES"
    echo "${YELLOW}Consider creating an issue for tracking.${NC}"
fi

# Check that package-lock.json or yarn.lock hasn't been modified without package.json
if echo "$STAGED_FILES" | grep -qE 'package-lock\.json|yarn\.lock'; then
    if ! echo "$STAGED_FILES" | grep -qE 'package\.json'; then
        echo "${YELLOW}WARNING: Lock file modified without package.json${NC}"
    fi
fi

# Run prettier on staged files if configured
if [ -f ".prettierrc" ] || [ -f ".prettierrc.json" ] || [ -f ".prettierrc.js" ]; then
    PRETTIER_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|jsx|ts|tsx|json|md|css|scss|yaml|yml)$' | grep -v node_modules | grep -v package-lock.json || true)
    if [ -n "$PRETTIER_FILES" ]; then
        echo "Running Prettier..."
        echo "$PRETTIER_FILES" | xargs npx prettier --write 2>/dev/null || true
        echo "$PRETTIER_FILES" | xargs git add 2>/dev/null || true
    fi
fi

echo "${GREEN}Pre-commit checks passed!${NC}"
exit 0
